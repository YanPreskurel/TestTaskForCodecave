@page "/calendar"
@rendermode InteractiveServer
@using SportsCalendar.Components.Calendar

<h3>Спортивный календарь</h3>

<div class="mb-3 d-flex justify-content-between align-items-center">
    <button class="btn btn-outline-primary" @onclick="PrevMonth">←</button>

    <h4 class="m-0">
        @CurrentMonth.ToString("MMMM yyyy")
    </h4>

    <button class="btn btn-outline-primary" @onclick="NextMonth">→</button>
</div>

<div class="row">

    <!-- Календарь -->
    <div class="col-8">

        <table class="table table-bordered text-center align-middle">

            <thead class="table-light">
                <tr>
                    @foreach (var day in DayNames)
                    {
                        <th>@day</th>
                    }
                </tr>
            </thead>

            <tbody>

                @foreach (var week in MonthMatrix)
                {
                    <tr>

                        @foreach (var day in week)
                        {
                            var isToday = day.Date == DateTime.Today.Date;
                            var isSelected = day.Date == SelectedDay.Date;
                            var isCurrentMonth = day.Month == CurrentMonth.Month;

                            var css =
                            (isToday ? "table-primary " : "") +
                            (isSelected ? "table-warning " : "") +
                            (!isCurrentMonth ? "text-muted " : "") +
                            "cursor-pointer";

                            <td class="@css"
                                @onclick="() => SelectDay(day)">

                                @day.Day

                            </td>
                        }

                    </tr>
                }

            </tbody>

        </table>

    </div>


    <!-- Dashboard -->
    <div class="col-4">

        @if (SelectedDay != DateTime.MinValue)
        {
            <DayDashboard @ref="DashboardRef"
                          Date="SelectedDay" />
        }
        else
        {
            <div class="alert alert-info">
                Выберите день, чтобы увидеть упражнения
            </div>
        }

    </div>

</div>


@code {

    private readonly string[] DayNames =
    {
        "Пн","Вт","Ср","Чт","Пт","Сб","Вс"
    };

    private DateTime CurrentMonth = DateTime.Today;

    private List<List<DateTime>> MonthMatrix = new();

    private DateTime SelectedDay = DateTime.Today;

    private DayDashboard DashboardRef;


    protected override void OnInitialized()
    {
        BuildCalendar();
    }


    void BuildCalendar()
    {
        MonthMatrix.Clear();

        var firstDay = new DateTime(CurrentMonth.Year, CurrentMonth.Month, 1);

        int diff = (7 + (firstDay.DayOfWeek - DayOfWeek.Monday)) % 7;

        var start = firstDay.AddDays(-diff);

        for (int week = 0; week < 6; week++)
        {
            var days = new List<DateTime>();

            for (int day = 0; day < 7; day++)
            {
                days.Add(start.AddDays(week * 7 + day));
            }

            MonthMatrix.Add(days);
        }
    }


    void PrevMonth()
    {
        CurrentMonth = CurrentMonth.AddMonths(-1);
        BuildCalendar();
        StateHasChanged();
    }

    void NextMonth()
    {
        CurrentMonth = CurrentMonth.AddMonths(1);
        BuildCalendar();
        StateHasChanged();
    }


    void SelectDay(DateTime day)
    {
        SelectedDay = day;
    }

}